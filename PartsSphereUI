/* ══ PORTAL SWITCH ══ */
function switchPortal(name){
  document.querySelectorAll(".portal").forEach(p=>p.classList.remove("active"));
  document.getElementById("portal" + name.charAt(0).toUpperCase() + name.slice(1)).classList.add("active");
  document.querySelectorAll(".portal-switch button").forEach((b,i)=>b.classList.toggle("active", (i===0&&name==="customer")||(i===1&&name==="supplier")));
  if(name === "supplier"){ renderSupplierDash(); }
}

/* ══ VEHICLE FITMENT ══ */
const fitMake = document.getElementById("fitMake");
const fitModel = document.getElementById("fitModel");
const fitYear = document.getElementById("fitYear");
Object.keys(VEHICLE_DATA).forEach(make=>{
  const o = document.createElement("option"); o.value=make; o.textContent=make; fitMake.appendChild(o);
});
fitMake.addEventListener("change",()=>{
  fitModel.innerHTML = '<option value="">Model</option>';
  fitYear.innerHTML = '<option value="">Year</option>';
  const d = VEHICLE_DATA[fitMake.value];
  if(d){ d.models.forEach(m=>{const o=document.createElement("option");o.value=m;o.textContent=m;fitModel.appendChild(o);}); d.years.forEach(y=>{const o=document.createElement("option");o.value=y;o.textContent=y;fitYear.appendChild(o);}); }
});
document.getElementById("fitApply").onclick = ()=>{
  if(!fitMake.value||!fitModel.value){ document.getElementById("fitStatus").textContent="Choose make and model first."; document.getElementById("fitStatus").className="vin-status"; return; }
  selectedVehicle = {make:fitMake.value,model:fitModel.value,year:fitYear.value};
  const compat = PARTS.filter(p=>p.fitsMakes.includes(selectedVehicle.make)).length;
  document.getElementById("fitStatus").textContent = compat + " parts confirmed compatible with your " + (fitYear.value||"") + " " + fitMake.value + " " + fitModel.value + ".";
  document.getElementById("fitStatus").className = "vin-status ok";
  renderParts(); showToast("Fitment applied — showing compatible parts first.");
};

/* ══ CATEGORIES ══ */
function buildCategoryPills(){
  const cats = ["all",...new Set(PARTS.map(p=>p.category))].sort();
  const container = document.getElementById("catPills");
  container.innerHTML = cats.map(c=>`<div class="cat-pill ${c==="all"?"active":""}" data-cat="${c}">${c==="all"?"All Parts":c}</div>`).join("");
  container.querySelectorAll(".cat-pill").forEach(el=>{
    el.onclick=()=>{ container.querySelectorAll(".cat-pill").forEach(x=>x.classList.remove("active")); el.classList.add("active"); activeCategory=el.dataset.cat; renderParts(); };
  });
}

