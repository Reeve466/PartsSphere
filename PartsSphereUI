<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>PartSphere — B2B Automotive Parts Marketplace</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0a0c10; --surface:#12151c; --surface-2:#181d26; --surface-3:#1e2531;
  --border:#232a36; --border-soft:#1a202b;
  --steel:#3B6E91; --steel-lt:#6FA1C2; --steel-ink:#040e18;
  --amber:#E8A33D; --amber-dim:#c98a26; --amber-ink:#1a1200;
  --sage:#40916C; --sage-bg:#0f2019;
  --danger:#e15b5b; --danger-bg:#241213;
  --warn:#d4a017; --warn-bg:#1f1800;
  --text:#edeff2; --text-dim:#9099a8; --text-faint:#5a6274;
  --radius:14px; --radius-sm:8px;
  --shadow:0 20px 50px -20px rgba(0,0,0,.6);
  --font-d:'Space Grotesk',sans-serif; --font-b:'Inter',sans-serif; --font-m:'IBM Plex Mono',monospace;
}
*{box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html{scroll-behavior:smooth;}
body{margin:0;font-family:var(--font-b);background:var(--bg);color:var(--text);padding-bottom:80px;}
h1,h2,h3,h4{font-family:var(--font-d);font-weight:600;margin:0;letter-spacing:-.01em;}
p{margin:0;} button{font-family:inherit;} a{color:inherit;}
::selection{background:var(--amber);color:var(--amber-ink);}
.mono{font-family:var(--font-m);}

/* ── TOP NAV ── */
.topbar{
  position:sticky;top:0;z-index:900;
  display:flex;align-items:center;gap:16px;padding:13px 24px;
  background:rgba(10,12,16,.92);backdrop-filter:blur(12px);
  border-bottom:1px solid var(--border-soft);
}
.logo{font-size:18px;font-weight:700;display:flex;align-items:center;gap:9px;white-space:nowrap;}
.logo .mark{width:32px;height:32px;border-radius:10px;background:var(--steel);display:flex;align-items:center;justify-content:center;font-size:14px;}
.logo em{color:var(--steel);font-style:normal;}
.portal-switch{display:flex;gap:0;background:var(--surface);border:1px solid var(--border);border-radius:9px;overflow:hidden;margin-left:auto;}
.portal-switch button{border:none;background:none;color:var(--text-dim);padding:8px 16px;font-size:12.5px;font-weight:600;cursor:pointer;transition:.15s;}
.portal-switch button.active{background:var(--steel);color:#fff;}
.topbar-actions{display:flex;align-items:center;gap:10px;}
.icon-btn{background:var(--surface);border:1px solid var(--border);border-radius:9px;width:38px;height:38px;display:flex;align-items:center;justify-content:center;cursor:pointer;position:relative;color:var(--text);}
.icon-btn svg{width:18px;height:18px;stroke:currentColor;fill:none;stroke-width:1.8;}
.badge{position:absolute;top:-4px;right:-4px;background:var(--amber);color:var(--amber-ink);font-size:9.5px;font-weight:700;border-radius:9px;min-width:17px;height:17px;display:flex;align-items:center;justify-content:center;padding:0 4px;}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:7px;border-radius:9px;font-weight:600;cursor:pointer;border:none;padding:9px 18px;font-size:13.5px;transition:.15s;}
.btn-amber{background:var(--amber);color:var(--amber-ink);}
.btn-amber:hover{background:#f0b558;}
.btn-steel{background:var(--steel);color:#fff;}
.btn-steel:hover{background:var(--steel-lt);}
.btn-ghost{background:transparent;border:1px solid var(--border);color:var(--text-dim);}
.btn-ghost:hover{border-color:var(--steel);color:var(--text);}
.btn-sm{padding:6px 13px;font-size:12px;}
.btn-danger{background:var(--danger-bg);color:var(--danger);border:1px solid var(--danger);}

/* ── PORTAL VIEWS ── */
.portal{display:none;} .portal.active{display:block;}

/* ── SHARED SECTION ── */
.wrap{max-width:1280px;margin:0 auto;padding:0 24px;}
.section-head{display:flex;justify-content:space-between;align-items:flex-end;margin:28px 0 16px;flex-wrap:wrap;gap:12px;}
.section-head h2{font-size:20px;}
.kicker{font-size:11px;color:var(--text-faint);text-transform:uppercase;letter-spacing:.08em;margin-bottom:5px;display:block;}
.muted{color:var(--text-dim);}
.result-count{font-size:12px;color:var(--text-faint);}

/* ── CARDS ── */
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);box-shadow:0 2px 8px rgba(0,0,0,.12);}
.card-pad{padding:20px;}

/* ── HERO ── */
.hero{padding:40px 0 32px;}
.hero-inner{display:grid;grid-template-columns:1.3fr 0.9fr;gap:24px;align-items:center;}
.hero h1{font-size:clamp(2rem,4vw,3.5rem);line-height:1.08;margin-bottom:14px;}
.hero h1 em{color:var(--steel-lt);font-style:normal;}
.hero p.lead{color:var(--text-dim);font-size:15px;line-height:1.6;max-width:480px;margin-bottom:24px;}
.hero-stats{display:flex;gap:28px;}
.hero-stats .stat b{display:block;font-family:var(--font-m);font-size:24px;color:var(--amber);}
.hero-stats .stat span{font-size:11.5px;color:var(--text-faint);text-transform:uppercase;letter-spacing:.05em;}
.hero-cta{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:24px;}

/* VIN finder card */
.vin-card{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:22px;}
.vin-card h3{font-size:15px;margin-bottom:14px;color:var(--text-dim);}
.vin-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.vin-grid input,.vin-grid select{background:var(--surface-2);border:1px solid var(--border);border-radius:9px;padding:10px 13px;color:var(--text);font-size:13px;width:100%;}
.vin-grid input:focus,.vin-grid select:focus{outline:none;border-color:var(--steel);}
.vin-status{font-size:12px;margin-top:10px;color:var(--text-faint);}
.vin-status.ok{color:var(--sage);}

/* ── FILTERS ── */
.filter-bar{display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin-bottom:18px;}
.search-box{display:flex;align-items:center;gap:8px;background:var(--surface);border:1px solid var(--border);border-radius:9px;padding:0 14px;flex:1;min-width:200px;}
.search-box input{background:none;border:none;color:var(--text);font-size:13.5px;padding:10px 0;width:100%;}
.search-box input::placeholder{color:var(--text-faint);}
.search-box svg{width:16px;height:16px;stroke:var(--text-faint);fill:none;stroke-width:2;flex-shrink:0;}
.filter-select{background:var(--surface);border:1px solid var(--border);border-radius:9px;padding:10px 13px;color:var(--text);font-size:13px;}
.cat-pills{display:flex;gap:7px;flex-wrap:wrap;}
.cat-pill{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:6px 14px;font-size:12.5px;font-weight:600;color:var(--text-dim);cursor:pointer;transition:.12s;}
.cat-pill.active,.cat-pill:hover{background:var(--steel);border-color:var(--steel);color:#fff;}

/* ── PRODUCT GRID ── */
.product-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(235px,1fr));gap:16px;}
.p-card{display:flex;flex-direction:column;gap:10px;padding:16px;}
.p-icon{width:52px;height:52px;border-radius:12px;background:var(--surface-3);display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0;}
.p-icon.ps{font-size:14px;font-weight:700;color:var(--steel-lt);font-family:var(--font-m);}
.p-badges{display:flex;gap:5px;flex-wrap:wrap;}
.pill{display:inline-flex;align-items:center;gap:4px;border-radius:20px;padding:4px 9px;font-size:11px;font-weight:600;}
.pill.verified{background:rgba(64,145,108,.18);color:var(--sage);}
.pill.fit{background:rgba(64,145,108,.18);color:var(--sage);}
.pill.nofit{background:var(--danger-bg);color:var(--danger);}
.pill.warn{background:var(--warn-bg);color:var(--warn);}
.pill.stock-ok{background:rgba(64,145,108,.14);color:var(--sage);}
.pill.stock-low{background:var(--warn-bg);color:var(--warn);}
.pill.stock-order{background:var(--surface-3);color:var(--text-faint);}
.p-card h3{font-size:14.5px;margin:0;line-height:1.3;}
.p-brand{font-size:12px;color:var(--text-faint);}
.p-price{font-family:var(--font-m);font-size:20px;color:var(--amber);margin-top:auto;}
.p-card-foot{display:flex;gap:7px;margin-top:2px;}
.cert-tags{display:flex;gap:5px;flex-wrap:wrap;}
.cert-tag{font-size:10.5px;background:var(--surface-3);border:1px solid var(--border);border-radius:5px;padding:3px 7px;color:var(--text-faint);}

/* ── RFQ DRAWER ── */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:1800;opacity:0;pointer-events:none;transition:.2s;}
.overlay.show{opacity:1;pointer-events:auto;}
.drawer{position:fixed;top:0;right:0;height:100%;width:360px;max-width:92vw;background:var(--surface);z-index:1900;transform:translateX(100%);transition:transform .28s cubic-bezier(.4,0,.2,1);display:flex;flex-direction:column;box-shadow:-12px 0 40px rgba(0,0,0,.25);}
.drawer.open{transform:translateX(0);}
.drawer-head{padding:18px 20px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;}
.drawer-head h3{font-size:16px;}
.drawer-close{background:none;border:none;color:var(--text-faint);font-size:22px;cursor:pointer;line-height:1;}
.drawer-body{flex:1;overflow-y:auto;padding:16px 20px;}
.drawer-foot{padding:16px 20px;border-top:1px solid var(--border);}
.cart-line{display:flex;justify-content:space-between;align-items:flex-start;padding:12px 0;border-bottom:1px solid var(--border-soft);gap:8px;}
.cart-line .info b{font-size:13.5px;display:block;}
.cart-line .info span{font-size:11.5px;color:var(--text-faint);}
.cart-line .remove{background:none;border:none;color:var(--text-faint);cursor:pointer;font-size:18px;flex-shrink:0;}
.cart-line .remove:hover{color:var(--danger);}
.cart-empty{color:var(--text-faint);font-size:13.5px;text-align:center;padding:32px 10px;}
.cart-total{display:flex;justify-content:space-between;font-size:14px;font-weight:600;margin:14px 0;}
.cart-total b{font-family:var(--font-m);color:var(--amber);}

/* ── PART MODAL ── */
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.72);z-index:2200;display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;pointer-events:none;transition:.18s;}
.modal-bg.show{opacity:1;pointer-events:auto;}
.modal-box{background:var(--surface);border:1px solid var(--border);border-radius:16px;width:640px;max-width:100%;max-height:88vh;overflow-y:auto;position:relative;padding:26px;}
.modal-close{position:absolute;top:14px;right:16px;background:none;border:none;color:var(--text-faint);font-size:24px;cursor:pointer;}
.modal-inner{display:flex;gap:22px;flex-wrap:wrap;}
.modal-icon{width:140px;height:140px;border-radius:14px;background:var(--surface-3);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:52px;flex-shrink:0;}
.modal-info{flex:1;min-width:200px;}
.modal-info h2{font-size:21px;margin-bottom:4px;}
.modal-info .brand{color:var(--text-faint);font-size:13px;margin-bottom:10px;}
.modal-price{font-family:var(--font-m);font-size:26px;color:var(--amber);font-weight:600;margin:10px 0;}
.modal-meta{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:14px 0;}
.modal-meta-item span{display:block;font-size:10.5px;color:var(--text-faint);text-transform:uppercase;letter-spacing:.05em;}
.modal-meta-item b{font-size:14px;}
.modal-actions{display:flex;gap:10px;margin-top:18px;}

/* ── PAYMENT MODAL ── */
.pay-modal-box{width:560px;max-width:100%;}
.pay-steps{display:flex;gap:0;margin-bottom:22px;border-radius:9px;overflow:hidden;border:1px solid var(--border);}
.pay-step{flex:1;padding:10px 8px;text-align:center;font-size:12px;font-weight:600;background:var(--surface-3);color:var(--text-faint);transition:.15s;}
.pay-step.active{background:var(--steel);color:#fff;}
.pay-step.done{background:var(--sage-bg);color:var(--sage);}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;}
.form-row.full{grid-template-columns:1fr;}
.form-group{display:flex;flex-direction:column;gap:5px;}
.form-group label{font-size:12px;color:var(--text-faint);font-weight:600;}
.form-group input,.form-group select{background:var(--surface-2);border:1px solid var(--border);border-radius:9px;padding:11px 13px;color:var(--text);font-size:13.5px;}
.form-group input:focus,.form-group select:focus{outline:none;border-color:var(--steel);}
.card-num-row{display:flex;gap:8px;align-items:center;}
.card-icons{display:flex;gap:6px;flex-shrink:0;}
.card-icon{width:36px;height:24px;border-radius:5px;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:9.5px;font-weight:700;background:var(--surface-3);}
.card-icon.visa{color:#1a72d9;}
.card-icon.mc{color:#eb5c28;}
.card-icon.amex{color:#36a5f0;}
.pay-summary{background:var(--surface-3);border:1px solid var(--border);border-radius:10px;padding:16px;margin-bottom:18px;}
.pay-summary-line{display:flex;justify-content:space-between;font-size:13.5px;padding:4px 0;}
.pay-summary-line.total{font-weight:700;font-size:15px;border-top:1px solid var(--border);margin-top:8px;padding-top:10px;}
.pay-summary-line.total b{font-family:var(--font-m);color:var(--amber);}
.escrow-notice{background:rgba(64,145,108,.1);border:1px solid rgba(64,145,108,.3);border-radius:9px;padding:11px 14px;font-size:12.5px;color:var(--sage);margin:14px 0;display:flex;gap:9px;align-items:flex-start;}
.escrow-notice svg{width:16px;height:16px;flex-shrink:0;margin-top:1px;stroke:var(--sage);fill:none;stroke-width:2;}
.pay-method-tabs{display:flex;gap:7px;margin-bottom:16px;flex-wrap:wrap;}
.pay-method-tab{border:1px solid var(--border);border-radius:9px;padding:9px 14px;font-size:13px;font-weight:600;background:var(--surface-2);color:var(--text-dim);cursor:pointer;transition:.14s;}
.pay-method-tab.active{border-color:var(--steel);background:rgba(59,110,145,.15);color:var(--steel-lt);}
.success-screen{text-align:center;padding:24px 0;}
.success-icon{font-size:60px;margin-bottom:14px;}
.success-screen h3{font-size:22px;margin-bottom:8px;}
.success-screen p{color:var(--text-dim);font-size:14px;line-height:1.6;}
.order-ref{font-family:var(--font-m);color:var(--amber);font-size:15px;margin:14px 0;}
.tracking-steps{display:flex;flex-direction:column;gap:0;margin-top:18px;text-align:left;}
.tracking-step{display:flex;gap:12px;align-items:flex-start;padding:10px 0;border-bottom:1px solid var(--border-soft);}
.tracking-step:last-child{border:none;}
.t-dot{width:12px;height:12px;border-radius:50%;flex-shrink:0;margin-top:4px;}
.t-dot.done{background:var(--sage);}
.t-dot.active{background:var(--amber);}
.t-dot.wait{background:var(--surface-3);border:2px solid var(--border);}
.t-step-text b{font-size:13.5px;display:block;}
.t-step-text span{font-size:11.5px;color:var(--text-faint);}

/* ── SUPPLIER SIDEBAR ── */
.shell{display:flex;min-height:100vh;}
.sup-sidebar{width:220px;flex-shrink:0;background:var(--surface);border-right:1px solid var(--border-soft);display:flex;flex-direction:column;padding:18px 12px;position:sticky;top:62px;height:calc(100vh - 62px);overflow-y:auto;}
.sup-main{flex:1;min-width:0;padding:22px 24px;}
.nav-group{margin-bottom:16px;}
.nav-label{font-size:10px;color:var(--text-faint);text-transform:uppercase;letter-spacing:.08em;padding:0 9px;margin-bottom:5px;display:block;}
.nav-item{display:flex;align-items:center;justify-content:space-between;gap:8px;padding:9px 10px;border-radius:9px;border:none;background:none;color:var(--text-dim);font-size:13.5px;width:100%;text-align:left;cursor:pointer;font-family:var(--font-b);}
.nav-item.active,.nav-item:hover{background:rgba(59,110,145,.18);color:var(--text);}
.nav-item svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:1.8;flex-shrink:0;}
.nav-count{background:var(--surface-3);border-radius:20px;font-size:10.5px;padding:2px 7px;color:var(--text-dim);}
.page-section{display:none;} .page-section.active{display:block;}
.sup-stat-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px;margin-bottom:22px;}
.sup-stat{padding:16px;}
.sup-stat .label{font-size:11px;color:var(--text-faint);margin-bottom:4px;}
.sup-stat .value{font-family:var(--font-m);font-size:22px;font-weight:600;}
.sup-stat .sub{font-size:11px;color:var(--text-faint);margin-top:2px;}
.table-wrap{overflow-x:auto;}
table{width:100%;border-collapse:collapse;}
th{text-align:left;font-size:11px;color:var(--text-faint);text-transform:uppercase;letter-spacing:.06em;padding:10px 12px;border-bottom:1px solid var(--border);}
td{padding:12px 12px;font-size:13.5px;border-bottom:1px solid var(--border-soft);vertical-align:top;}
tr:last-child td{border:none;}
.status-pill{display:inline-block;border-radius:20px;padding:4px 10px;font-size:11.5px;font-weight:600;}
.status-pill.new{background:rgba(59,110,145,.2);color:var(--steel-lt);}
.status-pill.quoted{background:var(--warn-bg);color:var(--warn);}
.status-pill.accepted{background:var(--sage-bg);color:var(--sage);}
.status-pill.fulfilling{background:rgba(232,163,61,.15);color:var(--amber);}
.status-pill.shipped{background:rgba(64,145,108,.18);color:var(--sage);}
.status-pill.delivered{background:var(--surface-3);color:var(--text-faint);}
.status-pill.active{background:rgba(64,145,108,.18);color:var(--sage);}
.status-pill.inactive{background:var(--surface-3);color:var(--text-faint);}
.stock-bar-wrap{display:flex;align-items:center;gap:8px;}
.stock-bar{width:60px;height:6px;background:var(--surface-3);border-radius:3px;overflow:hidden;}
.stock-bar-fill{height:100%;border-radius:3px;background:var(--sage);}
.stock-bar-fill.low{background:var(--danger);}

/* ── TOAST ── */
#toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--surface-2);border:1px solid var(--border);border-radius:10px;padding:12px 20px;font-size:13.5px;font-weight:500;opacity:0;pointer-events:none;transition:.22s;z-index:3000;display:flex;align-items:center;gap:10px;box-shadow:0 8px 24px rgba(0,0,0,.3);white-space:nowrap;}
#toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
#toast .dot{width:7px;height:7px;border-radius:50%;background:var(--sage);flex-shrink:0;}

/* ── CHARTS ── */
.chart-grid{display:grid;grid-template-columns:1.45fr 1fr;gap:16px;margin-top:16px;}
.chart-wrap{padding:20px;}
.chart-title{font-size:13.5px;font-weight:600;margin-bottom:4px;}
.chart-sub{font-size:11.5px;color:var(--text-faint);margin-bottom:16px;}
.bar-chart{display:flex;align-items:flex-end;gap:5px;height:140px;border-bottom:1px solid var(--border);padding-bottom:0;position:relative;}
.bar-col{display:flex;flex-direction:column;align-items:center;gap:4px;flex:1;}
.bar-col .bar{width:100%;border-radius:4px 4px 0 0;background:var(--steel);transition:height .55s cubic-bezier(.4,0,.2,1);position:relative;min-height:4px;cursor:pointer;}
.bar-col .bar:hover{filter:brightness(1.2);}
.bar-col .bar.amber{background:var(--amber);}
.bar-col .bar.sage{background:var(--sage);}
.bar-col .bar.dual{background:linear-gradient(to top,var(--steel) 60%,var(--amber) 60%);}
.bar-col .bar-lbl{font-size:9px;color:var(--text-faint);margin-top:6px;white-space:nowrap;}
.bar-tooltip{display:none;position:absolute;top:-32px;left:50%;transform:translateX(-50%);background:var(--surface-2);border:1px solid var(--border);border-radius:6px;padding:3px 9px;font-size:10.5px;font-weight:600;color:var(--text);white-space:nowrap;z-index:20;}
.bar-col .bar:hover .bar-tooltip{display:block;}
.legend-row{display:flex;gap:16px;margin-top:12px;flex-wrap:wrap;}
.legend-item{display:flex;align-items:center;gap:6px;font-size:11px;color:var(--text-faint);}
.legend-dot{width:9px;height:9px;border-radius:3px;flex-shrink:0;}
.pipeline-wrap{display:flex;flex-direction:column;gap:9px;margin-top:6px;}
.pipeline-row{display:flex;align-items:center;gap:10px;}
.pipeline-label{font-size:11.5px;color:var(--text-dim);width:76px;flex-shrink:0;}
.pipeline-track{flex:1;height:26px;background:var(--surface-3);border-radius:5px;overflow:hidden;}
.pipeline-fill{height:100%;border-radius:5px;display:flex;align-items:center;padding-left:9px;font-size:11px;font-weight:600;color:#fff;transition:width .55s cubic-bezier(.4,0,.2,1);}
.pipeline-count{font-size:12px;font-weight:700;color:var(--text-dim);width:22px;text-align:right;flex-shrink:0;}
.donut-wrap{display:flex;align-items:center;gap:18px;margin-top:6px;}
.donut-legend{display:flex;flex-direction:column;gap:9px;}
.donut-item{display:flex;align-items:center;gap:8px;font-size:12px;}
.donut-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;}
.donut-item span{color:var(--text-faint);}
.donut-item b{font-family:var(--font-m);color:var(--text);}
.y-lines{position:absolute;inset:0;pointer-events:none;}
.y-line{position:absolute;left:0;right:0;border-top:1px dashed rgba(255,255,255,.05);}
@media(max-width:1000px){.chart-grid{grid-template-columns:1fr;}}
@media(max-width:780px){
  .hero-inner{grid-template-columns:1fr;}
  .product-grid{grid-template-columns:repeat(auto-fill,minmax(180px,1fr));}
  .modal-inner{flex-direction:column;}
  .modal-icon{width:100%;height:120px;}
  .form-row{grid-template-columns:1fr;}
  .shell{flex-direction:column;}
  .sup-sidebar{width:100%;height:auto;position:relative;top:0;flex-direction:row;overflow-x:auto;padding:10px 14px;}
  .nav-group{margin:0;display:flex;gap:4px;}
  .nav-label{display:none;}
}
</style>
</head>
<body>

<!-- ═══ TOP BAR ═══ -->
<nav class="topbar">
  <div class="logo"><div class="mark">PS</div>Part<em>Sphere</em></div>
  <div class="portal-switch">
    <button class="active" onclick="switchPortal('customer')">Workshop Portal</button>
    <button onclick="switchPortal('supplier')">Supplier Console</button>
  </div>
  <div class="topbar-actions">
    <button class="icon-btn" id="rfqBtn" title="RFQ Cart">
      <svg viewBox="0 0 24 24"><circle cx="9" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.5 3h2l2.4 12.4a2 2 0 0 0 2 1.6h8.6a2 2 0 0 0 2-1.6L21 8H6"/></svg>
      <span class="badge" id="cartBadge">0</span>
    </button>
  </div>
</nav>

<!-- ═══ CUSTOMER PORTAL ═══ -->
<div class="portal active" id="portalCustomer">
<div class="wrap">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div>
        <span class="kicker">OEM-verified B2B marketplace</span>
        <h1>Parts that fit, from suppliers you can <em>trust.</em></h1>
        <p class="lead">Search certified BMW and European automotive parts, confirm fitment against your vehicle, add to RFQ, and pay in escrow — all in one platform.</p>
        <div class="hero-stats">
          <div class="stat"><b id="statParts">0</b><span>Listed parts</span></div>
          <div class="stat"><b id="statSuppliers">0</b><span>Suppliers</span></div>
          <div class="stat"><b>&lt;4h</b><span>Supplier SLA</span></div>
          <div class="stat"><b>&lt;24h</b><span>Dispatch</span></div>
        </div>
      </div>
      <div class="vin-card">
        <h3>🔍 Fitment Finder</h3>
        <div class="vin-grid">
          <select id="fitMake"><option value="">Make</option></select>
          <select id="fitModel"><option value="">Model</option></select>
          <select id="fitYear"><option value="">Year</option></select>
          <input id="vinInput" placeholder="VIN (optional)" />
        </div>
        <button class="btn btn-steel" style="width:100%;margin-top:10px;" id="fitApply">Check fitment</button>
        <div class="vin-status" id="fitStatus">Select a vehicle to filter compatible parts.</div>
      </div>
    </div>
  </section>

  <!-- FILTERS -->
  <div class="filter-bar">
    <div class="search-box">
      <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
      <input id="searchInput" type="text" placeholder="Search parts, brands, categories…" />
    </div>
    <select class="filter-select" id="sortSelect">
      <option value="default">Sort: Default</option>
      <option value="price-asc">Price: Low → High</option>
      <option value="price-desc">Price: High → Low</option>
      <option value="name">Name A–Z</option>
    </select>
    <label style="display:flex;align-items:center;gap:7px;font-size:13px;color:var(--text-dim);cursor:pointer;">
      <input type="checkbox" id="verifiedOnly" style="accent-color:var(--sage);"> Verified only
    </label>
  </div>
  <div class="cat-pills" id="catPills" style="margin-bottom:18px;"></div>
  <div style="margin-bottom:12px;"><span class="result-count" id="resultCount"></span></div>

  <!-- PRODUCT GRID -->
  <div class="product-grid" id="productGrid"></div>

  <!-- SUPPLIERS STRIP -->
  <div class="section-head" style="margin-top:40px;"><h2>Verified OEM Suppliers</h2></div>
  <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:40px;" id="supplierStrip"></div>

</div><!-- /wrap -->
</div><!-- /portalCustomer -->

<!-- ═══ SUPPLIER PORTAL ═══ -->
<div class="portal" id="portalSupplier">
  <div class="shell">
    <aside class="sup-sidebar" id="supSidebar">
      <div class="nav-group">
        <span class="nav-label">Dashboard</span>
        <button class="nav-item active" data-page="dashboard">
          <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>
          Dashboard
        </button>
      </div>
      <div class="nav-group">
        <span class="nav-label">Orders</span>
        <button class="nav-item" data-page="rfq">
          <svg viewBox="0 0 24 24"><path d="M9 12h6M9 16h6M9 8h6M5 21h14a1 1 0 0 0 1-1V6l-4-4H6a1 1 0 0 0-1 1v17"/></svg>
