      </div>
      <div class="nav-group">
        <span class="nav-label">Settings</span>
        <button class="nav-item" data-page="settings">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
          Settings
        </button>
      </div>
    </aside>
    <main class="sup-main">
      <!-- Dashboard -->
      <div class="page-section active" id="page-dashboard">
        <h2 style="margin-bottom:18px;">Supplier Dashboard <span style="font-size:13px;color:var(--text-faint);font-weight:400;">· Bosch Certified Hub</span></h2>

        <!-- KPI strip -->
        <div class="sup-stat-grid">
          <div class="card sup-stat"><div class="label">Open RFQs</div><div class="value" id="kpiRfq">0</div><div class="sub">Needs response</div></div>
          <div class="card sup-stat"><div class="label">Orders to fulfil</div><div class="value" id="kpiOrders">0</div><div class="sub">Active shipments</div></div>
          <div class="card sup-stat"><div class="label">GMV this month</div><div class="value">€18,420</div><div class="sub" style="color:var(--sage);">▲ +12% vs last month</div></div>
          <div class="card sup-stat"><div class="label">SLA hit rate</div><div class="value" style="color:var(--sage);">96%</div><div class="sub">Confirmation &lt;4h</div></div>
          <div class="card sup-stat"><div class="label">Catalog parts</div><div class="value" id="kpiCatalog">0</div><div class="sub">Listed &amp; active</div></div>
          <div class="card sup-stat"><div class="label">Core returns ♻</div><div class="value" style="color:var(--sage);">8</div><div class="sub">This month</div></div>
        </div>

        <!-- Charts row -->
        <div class="chart-grid">

          <!-- Monthly GMV bar chart -->
          <div class="card chart-wrap">
            <div class="chart-title">Monthly Revenue (GMV) &amp; Orders</div>
            <div class="chart-sub">Last 9 months — commission earned per month</div>
            <div class="bar-chart" id="gmvChart"></div>
            <div class="legend-row">
              <div class="legend-item"><div class="legend-dot" style="background:var(--steel);"></div>GMV (€)</div>
              <div class="legend-item"><div class="legend-dot" style="background:var(--amber);"></div>Orders</div>
            </div>
          </div>

          <!-- RFQ Pipeline funnel -->
          <div class="card chart-wrap">
            <div class="chart-title">RFQ Pipeline</div>
            <div class="chart-sub">Current quote funnel status</div>
            <div class="pipeline-wrap" id="rfqPipeline"></div>

            <div style="margin-top:20px;">
              <div class="chart-title">Revenue by Category</div>
              <div class="chart-sub" style="margin-bottom:12px;">Share of GMV this month</div>
              <div class="donut-wrap">
                <svg class="donut-svg" width="90" height="90" viewBox="0 0 90 90" id="donutSvg">
                  <circle cx="45" cy="45" r="34" fill="none" stroke="var(--surface-3)" stroke-width="14"/>
                </svg>
                <div class="donut-legend" id="donutLegend"></div>
              </div>
            </div>
          </div>

        </div>

        <!-- Activity feed -->
        <div class="card card-pad" style="margin-top:16px;">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
            <h3>Recent activity</h3>
            <span style="font-size:11.5px;color:var(--text-faint);">Last 24 hours</span>
          </div>
          <div id="dashActivity"></div>
        </div>

      </div>
      <!-- RFQ -->
      <div class="page-section" id="page-rfq">
        <div class="section-head"><h2>RFQ Inbox</h2><button class="btn btn-ghost btn-sm" onclick="renderRfq()">Refresh</button></div>
        <div class="card table-wrap"><table><thead><tr><th>RFQ ID</th><th>Parts</th><th>Workshop</th><th>Value</th><th>Status</th><th>Action</th></tr></thead><tbody id="rfqTbody"></tbody></table></div>
      </div>
      <!-- Orders -->
      <div class="page-section" id="page-orders">
        <div class="section-head"><h2>Orders</h2></div>
        <div class="card table-wrap"><table><thead><tr><th>Order ID</th><th>Parts</th><th>Workshop</th><th>Value</th><th>Status</th><th>Action</th></tr></thead><tbody id="orderTbody"></tbody></table></div>
      </div>
      <!-- Catalog -->
      <div class="page-section" id="page-catalog">
        <div class="section-head"><h2>My Catalog</h2><button class="btn btn-amber btn-sm" onclick="openAddPart()">+ Add Part</button></div>
        <div class="card table-wrap"><table><thead><tr><th>Name</th><th>SKU</th><th>Category</th><th>Price</th><th>Stock</th><th>Status</th><th></th></tr></thead><tbody id="catalogTbody"></tbody></table></div>
      </div>
      <!-- Settings -->
      <div class="page-section" id="page-settings">
        <h2 style="margin-bottom:18px;">Supplier Settings</h2>
        <div class="card card-pad" style="max-width:560px;">
          <h3 style="margin-bottom:16px;">Company Profile</h3>
          <div class="form-row"><div class="form-group"><label>Company name</label><input value="Bosch Certified Hub"></div><div class="form-group"><label>Contact email</label><input value="ops@bosch-hub.demo"></div></div>
          <div class="form-row"><div class="form-group"><label>Warehouse city</label><input value="Nuremberg, DE"></div><div class="form-group"><label>ProVerified status</label><select><option>✓ ProVerified</option><option>Under review</option></select></div></div>
          <h3 style="margin:20px 0 14px;">Certifications</h3>
          <div style="display:flex;gap:8px;flex-wrap:wrap;">
            <span class="cert-tag" style="padding:6px 12px;">ISO 9001 ✓</span>
            <span class="cert-tag" style="padding:6px 12px;">IATF 16949 ✓</span>
            <span class="cert-tag" style="padding:6px 12px;">ISO 27001 ✓</span>
            <span class="cert-tag" style="padding:6px 12px;">CAPA ✓</span>
          </div>
          <button class="btn btn-amber" style="margin-top:20px;">Save changes</button>
        </div>
      </div>
    </main>
  </div>
</div><!-- /portalSupplier -->

<!-- ═══ RFQ DRAWER ═══ -->
<div class="overlay" id="drawerOverlay"></div>
<div class="drawer" id="rfqDrawer">
  <div class="drawer-head">
    <h3>RFQ Cart</h3>
    <button class="drawer-close" id="closeDrawer">&times;</button>
  </div>
  <div class="drawer-body" id="cartItems"></div>
  <div class="drawer-foot">
    <div class="cart-total"><span>Estimated total</span><b id="cartTotal">€0</b></div>
    <button class="btn btn-amber" style="width:100%;margin-bottom:8px;" id="proceedPayBtn">Proceed to payment</button>
    <button class="btn btn-ghost" style="width:100%;font-size:12.5px;" id="clearCartBtn">Clear cart</button>
  </div>
</div>

<!-- ═══ PART DETAIL MODAL ═══ -->
<div class="modal-bg" id="partModal">
  <div class="modal-box">
    <button class="modal-close" id="closePartModal">&times;</button>
    <div class="modal-inner">
      <div class="modal-icon" id="mIcon">🔧</div>
      <div class="modal-info">
        <h2 id="mTitle">—</h2>
        <p class="brand" id="mBrand">—</p>
        <div class="cert-tags" id="mCerts" style="margin-bottom:10px;"></div>
        <div class="modal-price" id="mPrice">€0</div>
        <div class="modal-meta">
          <div class="modal-meta-item"><span>SKU</span><b class="mono" id="mSku">—</b></div>
          <div class="modal-meta-item"><span>Lead time</span><b id="mLead">—</b></div>
          <div class="modal-meta-item"><span>Stock</span><b id="mStock">—</b></div>
          <div class="modal-meta-item"><span>Supplier</span><b id="mSupplier">—</b></div>
        </div>
        <div class="modal-actions">
          <button class="btn btn-amber" id="mAddCart">Add to RFQ</button>
          <button class="btn btn-ghost" id="closePartModal2">Close</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ═══ PAYMENT MODAL ═══ -->
<div class="modal-bg" id="payModal">
  <div class="modal-box pay-modal-box">
    <button class="modal-close" id="closePayModal">&times;</button>
    <h2 id="payModalTitle" style="margin-bottom:18px;">Payment &amp; Checkout</h2>

    <!-- Step indicators -->
    <div class="pay-steps" id="paySteps">
      <div class="pay-step active" id="payStep1">1. Details</div>
      <div class="pay-step" id="payStep2">2. Payment</div>
      <div class="pay-step" id="payStep3">3. Confirm</div>
    </div>

    <!-- Step 1: Delivery details -->
    <div id="payPane1">
      <div class="form-row">
        <div class="form-group"><label>Workshop name</label><input id="pWorkshop" value="Alpha Garage Nuremberg" /></div>
        <div class="form-group"><label>Contact name</label><input id="pContact" value="Max Mustermann" /></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>Email</label><input id="pEmail" type="email" value="max@alphagarage.demo" /></div>
        <div class="form-group"><label>Phone</label><input id="pPhone" value="+49 911 555 108" /></div>
      </div>
      <div class="form-row full">
        <div class="form-group"><label>Delivery address</label><input id="pAddress" value="Fürther Straße 100, 90429 Nürnberg, Germany" /></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>Delivery tier</label>
          <select id="pDelivery">
            <option value="24h">24h Standard (€12.00)</option>
            <option value="sameday">Same-day Metro (€24.00)</option>
            <option value="order">7–10 day Built-to-order (€6.00)</option>
          </select>
        </div>
        <div class="form-group"><label>Core return</label>
          <select id="pCore">
            <option>Collect old part at delivery</option>
            <option>Return later with prepaid label</option>
          </select>
        </div>
      </div>
      <div class="form-row full">
        <div class="form-group"><label>Carrier partner</label>
          <select id="pCarrier">
            <option>DHL Freight Auto</option>
            <option>DB Schenker PartsLine</option>
            <option>DPD Workshop Express</option>
          </select>
        </div>
      </div>
      <button class="btn btn-amber" style="width:100%;margin-top:8px;" onclick="payGoStep(2)">Continue to payment →</button>
    </div>

    <!-- Step 2: Payment -->
    <div id="payPane2" style="display:none;">
      <div class="pay-summary" id="paySummary"></div>
      <div class="escrow-notice">
        <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span>Your payment is held in <strong>escrow</strong> and only released to the supplier after dispatch is confirmed. If the supplier misses the 4h SLA, you get a full refund automatically.</span>
      </div>
      <div class="pay-method-tabs">
        <button class="pay-method-tab active" onclick="setPayMethod('card',this)">💳 Card</button>
        <button class="pay-method-tab" onclick="setPayMethod('invoice',this)">📄 Invoice + Escrow</button>
        <button class="pay-method-tab" onclick="setPayMethod('credit',this)">🏦 Account Credit</button>
      </div>
      <div id="cardForm">
        <div class="form-row full">
          <div class="form-group">
            <label>Card number</label>
            <div class="card-num-row">
              <input id="pCard" placeholder="4242 4242 4242 4242" style="flex:1;" oninput="formatCard(this)" maxlength="19" />
              <div class="card-icons">
                <div class="card-icon visa">VISA</div>
                <div class="card-icon mc">MC</div>
                <div class="card-icon amex">AMEX</div>
              </div>
            </div>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group"><label>Expiry</label><input id="pExpiry" placeholder="MM / YY" oninput="formatExpiry(this)" maxlength="7" /></div>
          <div class="form-group"><label>CVC</label><input id="pCvc" placeholder="•••" maxlength="4" type="password" /></div>
        </div>
        <div class="form-row full">
          <div class="form-group"><label>Cardholder name</label><input id="pName" value="Max Mustermann" /></div>
        </div>
      </div>
      <div id="invoiceForm" style="display:none;padding:14px;background:var(--surface-3);border-radius:9px;color:var(--text-dim);font-size:13.5px;">
        Invoice will be sent to <strong id="invoiceEmail">max@alphagarage.demo</strong>. Payment held in escrow until dispatch confirmed. Net 30 terms apply.
      </div>
      <div id="creditForm" style="display:none;padding:14px;background:var(--surface-3);border-radius:9px;color:var(--text-dim);font-size:13.5px;">
        Available credit: <strong style="color:var(--amber);">€4,200.00</strong>. Amount will be deducted after dispatch confirmation.
      </div>
      <div style="display:flex;gap:10px;margin-top:14px;">
        <button class="btn btn-ghost" style="flex:1;" onclick="payGoStep(1)">← Back</button>
        <button class="btn btn-amber" style="flex:2;" onclick="payGoStep(3)">Review order →</button>
      </div>
    </div>

    <!-- Step 3: Confirm -->
    <div id="payPane3" style="display:none;">
      <div class="pay-summary" id="paySummary2"></div>
      <div style="background:var(--surface-3);border-radius:9px;padding:13px;font-size:13px;color:var(--text-dim);margin-bottom:14px;">
        <strong style="color:var(--text);">📦 What happens next</strong><br>
        After confirming, the supplier has <strong>4 hours</strong> to accept. Parts will be dispatched within <strong>24 hours</strong>. You'll receive live tracking in your portal.
      </div>
      <div style="display:flex;gap:10px;">
        <button class="btn btn-ghost" style="flex:1;" onclick="payGoStep(2)">← Back</button>
        <button class="btn btn-amber" style="flex:2;" id="confirmPayBtn">✓ Confirm &amp; Pay</button>
      </div>
    </div>

    <!-- Step 4: Success -->
    <div id="payPane4" style="display:none;">
      <div class="success-screen">
        <div class="success-icon">🎉</div>
        <h3>Order confirmed!</h3>
        <p>Your payment is in escrow. The supplier has been notified and has 4 hours to confirm.</p>
        <div class="order-ref" id="orderRef">PS-000000</div>
        <div class="tracking-steps" id="trackingSteps"></div>
        <button class="btn btn-amber" style="margin-top:20px;width:100%;" onclick="closePayModal()">Close</button>
      </div>
    </div>
  </div>
</div>

<!-- Add Part Modal (Supplier) -->
<div class="modal-bg" id="addPartModal">
  <div class="modal-box" style="max-width:480px;">
    <button class="modal-close" onclick="closeAddPart()">&times;</button>
    <h2 style="margin-bottom:18px;">Add Part to Catalog</h2>
