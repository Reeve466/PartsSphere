  if(s.includes("bto")||s.includes("order")) return `<span class="pill stock-order">BTO</span>`;
  if(s.includes("stock")) return `<span class="pill stock-ok">In Stock</span>`;
  const n = parseInt(stock); if(!isNaN(n)){ if(n<=5) return `<span class="pill stock-low">Low (${n})</span>`; return `<span class="pill stock-ok">${n} units</span>`; }
  return `<span class="pill">${stock}</span>`;
}
function getFilteredParts(){
  let list = PARTS.filter(p=>{
    if(activeCategory!=="all" && p.category!==activeCategory) return false;
    if(verifiedOnly && !p.verified) return false;
    const q = searchValue.toLowerCase();
    if(q && !p.name.toLowerCase().includes(q) && !p.brand.toLowerCase().includes(q) && !p.category.toLowerCase().includes(q) && !p.sku.toLowerCase().includes(q)) return false;
    return true;
  });
  if(selectedVehicle){ list = [...list].sort((a,b)=>{ const af=a.fitsMakes.includes(selectedVehicle.make)?0:1; const bf=b.fitsMakes.includes(selectedVehicle.make)?0:1; return af-bf; }); }
  if(sortMode==="price-asc") list=[...list].sort((a,b)=>a.price-b.price);
  if(sortMode==="price-desc") list=[...list].sort((a,b)=>b.price-a.price);
  if(sortMode==="name") list=[...list].sort((a,b)=>a.name.localeCompare(b.name));
  return list;
}
function renderParts(){
  const list = getFilteredParts();
  document.getElementById("resultCount").textContent = list.length + " of " + PARTS.length + " parts";
  const grid = document.getElementById("productGrid");
  if(!list.length){ grid.innerHTML='<div style="color:var(--text-faint);padding:40px;text-align:center;grid-column:1/-1;">No parts match your filter. Try clearing the search or category.</div>'; return; }
  grid.innerHTML = list.map(p=>{
    const fitsV = selectedVehicle ? p.fitsMakes.includes(selectedVehicle.make) : null;
    const inCart = cart.some(c=>c.id===p.id);
    return `<div class="card p-card">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;">
        <div class="p-icon">${p.icon}</div>
        <div class="p-badges">
          ${p.verified?'<span class="pill verified">✓ OEM</span>':''}
          ${fitsV===true?'<span class="pill fit">✓ Fits</span>':''}
          ${fitsV===false?'<span class="pill nofit">Check fit</span>':''}
        </div>
      </div>
      <h3>${p.name}</h3>
      <div class="p-brand">${p.brand} · ${p.category}</div>
      <div class="cert-tags">${p.certs.map(c=>`<span class="cert-tag">${c}</span>`).join("")}</div>
      <div style="display:flex;align-items:center;gap:8px;margin-top:4px;">${getStockPill(p.stock)}<span style="font-size:11px;color:var(--text-faint);">${p.lead}</span></div>
      <div class="p-price">${money(p.price)}</div>
      <div class="p-card-foot">
        <button class="btn btn-amber btn-sm" style="flex:1;" onclick="addToCart(${p.id})">${inCart?"✓ Added":"Add to RFQ"}</button>
        <button class="btn btn-ghost btn-sm" onclick="openPartModal(${p.id})">View</button>
      </div>
    </div>`;
  }).join("");
}

/* ══ CART ══ */
function addToCart(id){
  const p = PARTS.find(x=>x.id===id);
  if(!p) return;
  if(cart.find(c=>c.id===id)){ showToast(p.name+" is already in your RFQ"); return; }
  cart.push(p); updateCartBadge(); renderCart();
  showToast(p.name+" added to RFQ cart");
  renderParts();
}
function removeFromCart(id){ cart = cart.filter(c=>c.id!==id); updateCartBadge(); renderCart(); renderParts(); }
function updateCartBadge(){ document.getElementById("cartBadge").textContent=cart.length; }
function renderCart(){
  const items = document.getElementById("cartItems");
  if(!cart.length){ items.innerHTML='<div class="cart-empty">Your RFQ cart is empty. Browse parts and add them here.</div>'; document.getElementById("cartTotal").textContent="€0"; return; }
  items.innerHTML = cart.map((p,i)=>`<div class="cart-line">
    <div class="info"><b>${p.name}</b><span>${p.brand} · ${money(p.price)}</span></div>
    <button class="remove" onclick="removeFromCart(${p.id})">&times;</button>
  </div>`).join("");
  document.getElementById("cartTotal").textContent = money(cart.reduce((s,p)=>s+p.price,0));
}
function openDrawer(){ document.getElementById("rfqDrawer").classList.add("open"); document.getElementById("drawerOverlay").classList.add("show"); renderCart(); }
function closeDrawer(){ document.getElementById("rfqDrawer").classList.remove("open"); document.getElementById("drawerOverlay").classList.remove("show"); }
function clearCart(){ cart=[]; updateCartBadge(); renderCart(); renderParts(); showToast("Cart cleared"); }

/* ══ PART MODAL ══ */
function openPartModal(id){
  const p = PARTS.find(x=>x.id===id); if(!p) return;
  document.getElementById("mIcon").textContent=p.icon;
  document.getElementById("mTitle").textContent=p.name;
  document.getElementById("mBrand").textContent=p.brand+" · "+p.category;
  document.getElementById("mPrice").textContent=money(p.price);
  document.getElementById("mSku").textContent=p.sku;
  document.getElementById("mLead").textContent=p.lead;
  document.getElementById("mStock").textContent=p.stock;
  document.getElementById("mSupplier").textContent=p.brand;
  document.getElementById("mCerts").innerHTML=p.certs.map(c=>`<span class="cert-tag">${c}</span>`).join("");
  document.getElementById("mAddCart").onclick=()=>{ addToCart(p.id); closeModal("partModal"); };
  showModal("partModal");
}

/* ══ PAYMENT MODAL ══ */
function openPayModal(){
  if(!cart.length){ showToast("Add parts to your cart first"); return; }
  closeDrawer();
  currentPayStep=1; showModal("payModal");
  payGoStep(1);
}
function payGoStep(step){
  currentPayStep=step;
  [1,2,3,4].forEach(i=>{
    document.getElementById("payPane"+i).style.display = i===step?"block":"none";
  });
  const steps = document.querySelectorAll("#paySteps .pay-step");
  steps.forEach((s,i)=>{
    s.classList.remove("active","done");
    if(i+1<step) s.classList.add("done");
    else if(i+1===step) s.classList.add("active");
  });
  if(step===2||step===3){ renderPaySummary(); }
  if(step===3){ document.getElementById("invoiceEmail").textContent=document.getElementById("pEmail").value||"max@alphagarage.demo"; }
}
function renderPaySummary(){
  const sub = cart.reduce((s,p)=>s+p.price,0);
  const shipping = {sameday:24,h24:12,order:6}[document.getElementById("pDelivery")?.value]||12;
  const escrow = +(sub*0.02).toFixed(2);
  const total = sub+shipping+escrow;
  const rows = cart.map(p=>`<div class="pay-summary-line"><span>${p.name}</span><b>${money(p.price)}</b></div>`).join("");
  const summary = `${rows}<div class="pay-summary-line"><span>Shipping (${document.getElementById("pCarrier")?.value||"DHL"})</span><b>${money(shipping)}</b></div><div class="pay-summary-line"><span>Platform escrow fee (2%)</span><b>${money(escrow)}</b></div><div class="pay-summary-line total"><span>Total</span><b>${money(total)}</b></div>`;
  ["paySummary","paySummary2"].forEach(id=>{ const el=document.getElementById(id); if(el) el.innerHTML=summary; });
}
function setPayMethod(method, el){
  payMethod=method;
  document.querySelectorAll(".pay-method-tab").forEach(t=>t.classList.remove("active"));
  el.classList.add("active");
  document.getElementById("cardForm").style.display=method==="card"?"block":"none";
  document.getElementById("invoiceForm").style.display=method==="invoice"?"block":"none";
  document.getElementById("creditForm").style.display=method==="credit"?"block":"none";
}
function formatCard(el){ el.value=el.value.replace(/\D/g,"").replace(/(.{4})/g,"$1 ").trim(); }
function formatExpiry(el){ el.value=el.value.replace(/\D/g,"").replace(/^(\d{2})(\d)/,"$1 / $2"); }
document.getElementById("confirmPayBtn").onclick = ()=>{
  const orderId = genOrderId();
  const sub = cart.reduce((s,p)=>s+p.price,0);
  const shipping = 12;
  const total = sub + shipping + (sub*0.02);
  document.getElementById("orderRef").textContent = orderId;
  const steps = [
    {label:"Order confirmed",desc:"Your order "+orderId+" has been created",state:"done"},
    {label:"Payment captured",desc:"Funds held in escrow — "+money(total),state:"done"},
    {label:"Supplier notified",desc:"Supplier has 4 hours to confirm",state:"active"},
    {label:"Dispatch",desc:"Target: within 24 hours",state:"wait"},
    {label:"Delivery",desc:"Live tracking in your portal",state:"wait"},
    {label:"Core return",desc:"Old part collected for remanufacturing ♻",state:"wait"},
  ];
  document.getElementById("trackingSteps").innerHTML = steps.map(s=>`<div class="tracking-step"><div class="t-dot ${s.state}"></div><div class="t-step-text"><b>${s.label}</b><span>${s.desc}</span></div></div>`).join("");
  payGoStep(4);
  cart=[]; updateCartBadge(); renderCart(); renderParts();
  showToast("Order "+orderId+" confirmed! 🎉");
};

/* ══ MODALS ══ */
function showModal(id){ document.getElementById(id).classList.add("show"); }
function closeModal(id){ document.getElementById(id).classList.remove("show"); }
function closePayModal(){ closeModal("payModal"); currentPayStep=1; }

document.getElementById("closePartModal").onclick = ()=>closeModal("partModal");
document.getElementById("closePartModal2").onclick = ()=>closeModal("partModal");
document.getElementById("closePayModal").onclick = closePayModal;
document.getElementById("partModal").onclick = e=>{ if(e.target.id==="partModal") closeModal("partModal"); };
document.getElementById("payModal").onclick = e=>{ if(e.target.id==="payModal") closePayModal(); };
document.addEventListener("keydown",e=>{ if(e.key==="Escape"){ closeModal("partModal"); closePayModal(); closeDrawer(); } });

/* ══ NAV EVENTS ══ */
document.getElementById("rfqBtn").onclick = openDrawer;
document.getElementById("closeDrawer").onclick = closeDrawer;
document.getElementById("drawerOverlay").onclick = closeDrawer;
document.getElementById("proceedPayBtn").onclick = openPayModal;
document.getElementById("clearCartBtn").onclick = clearCart;
document.getElementById("searchInput").oninput = e=>{ searchValue=e.target.value; renderParts(); };
document.getElementById("sortSelect").onchange = e=>{ sortMode=e.target.value; renderParts(); };
document.getElementById("verifiedOnly").onchange = e=>{ verifiedOnly=e.target.checked; renderParts(); };

/* ══ SUPPLIER PORTAL ══ */
document.querySelectorAll(".nav-item").forEach(btn=>btn.onclick=()=>{
  document.querySelectorAll(".nav-item").forEach(b=>b.classList.remove("active")); btn.classList.add("active");
  document.querySelectorAll(".page-section").forEach(s=>s.classList.remove("active")); document.getElementById("page-"+btn.dataset.page).classList.add("active");
});
/* ═══ GMV bar chart data ═══ */
const gmvMonths = [
  {mo:"Oct",gmv:9200,orders:28},
  {mo:"Nov",gmv:11400,orders:36},
  {mo:"Dec",gmv:14800,orders:44},
  {mo:"Jan",gmv:10200,orders:31},
  {mo:"Feb",gmv:12600,orders:39},
  {mo:"Mar",gmv:13900,orders:42},
  {mo:"Apr",gmv:15200,orders:47},
  {mo:"May",gmv:16800,orders:52},
  {mo:"Jun",gmv:18420,orders:57},
];
const catRevenue = [
  {label:"Filters",pct:28,color:"#3B6E91"},
  {label:"Brakes",pct:22,color:"#B5562F"},
  {label:"Engine",pct:18,color:"#40916C"},
  {label:"Electrical",pct:16,color:"#6B5CA5"},
  {label:"Other",pct:16,color:"#5B6573"},
];
const pipelineStages = [
  {label:"Incoming",count:12,color:"#3B6E91",pct:100},
  {label:"Quoted",count:8,color:"#D4A017",pct:67},
  {label:"Accepted",count:5,color:"#40916C",pct:42},
  {label:"Ordered",count:4,color:"#2E8B6E",pct:33},
  {label:"Shipped",count:3,color:"#4F8A3D",pct:25},
];

function renderGmvChart(){
  const container = document.getElementById("gmvChart");
  if(!container) return;
  const maxGmv = Math.max(...gmvMonths.map(m=>m.gmv));
  const maxOrd = Math.max(...gmvMonths.map(m=>m.orders));
  container.innerHTML = gmvMonths.map(m=>{
    const gmvH = Math.round((m.gmv/maxGmv)*120);
    const ordH = Math.round((m.orders/maxOrd)*120);
    return `<div class="bar-col">
      <div style="display:flex;gap:2px;align-items:flex-end;height:132px;">
        <div class="bar" style="height:${gmvH}px;width:10px;background:var(--steel);flex-shrink:0;">
          <div class="bar-tooltip">€${(m.gmv/1000).toFixed(1)}k</div>
        </div>
        <div class="bar amber" style="height:${ordH}px;width:8px;flex-shrink:0;">
          <div class="bar-tooltip">${m.orders} orders</div>
        </div>
      </div>
      <div class="bar-lbl">${m.mo}</div>
    </div>`;
  }).join("");
}

function renderPipeline(){
  const container = document.getElementById("rfqPipeline");
  if(!container) return;
  container.innerHTML = pipelineStages.map(s=>`
    <div class="pipeline-row">
      <div class="pipeline-label">${s.label}</div>
      <div class="pipeline-track">
        <div class="pipeline-fill" style="width:${s.pct}%;background:${s.color};">${s.count}</div>
      </div>
      <div class="pipeline-count">${s.count}</div>
    </div>`).join("");
}

function renderDonut(){
  const svg = document.getElementById("donutSvg");
  const legend = document.getElementById("donutLegend");
  if(!svg||!legend) return;
  const r=34, cx=45, cy=45, circ=2*Math.PI*r;
  let offset=0;
  let circles="<circle cx='45' cy='45' r='34' fill='none' stroke='var(--surface-3)' stroke-width='14'/>";
  catRevenue.forEach(c=>{
    const dash = (c.pct/100)*circ;
    const gap = circ-dash;
    // rotate so it starts from top (-90deg = -circ/4 offset)
    circles += `<circle cx='${cx}' cy='${cy}' r='${r}' fill='none' stroke='${c.color}' stroke-width='14'
      stroke-dasharray='${dash.toFixed(1)} ${gap.toFixed(1)}'
      stroke-dashoffset='${(circ/4 - offset*circ/100).toFixed(1)}'
      style='transition:stroke-dashoffset .5s'/>`;
    offset += c.pct;
  });
  svg.innerHTML = circles;
  legend.innerHTML = catRevenue.map(c=>`<div class="donut-item"><div class="donut-dot" style="background:${c.color};"></div><span>${c.label}</span><b>${c.pct}%</b></div>`).join("");
}

function renderSupplierDash(){
  document.getElementById("kpiRfq").textContent = supplierRfqs.filter(r=>r.status==="new").length;
  document.getElementById("kpiOrders").textContent = supplierOrders.filter(o=>o.status==="fulfilling").length;
  document.getElementById("kpiCatalog").textContent = supplierCatalog.filter(c=>c.active).length;
  document.getElementById("rfqCountBadge").textContent = supplierRfqs.filter(r=>r.status==="new").length;
  document.getElementById("orderCountBadge").textContent = supplierOrders.filter(o=>o.status==="fulfilling").length;

  // Render charts
  renderGmvChart();
  renderPipeline();
  renderDonut();

  // Activity feed
  const activities = [
    ...supplierRfqs.map(r=>({icon:"📋",text:`RFQ <b>${r.id}</b> from ${r.workshop}`,status:r.status,time:"2h ago"})),
    ...supplierOrders.map(o=>({icon:"📦",text:`Order <b>${o.id}</b> — ${money(o.value)}`,status:o.status,time:"4h ago"})),
    {icon:"♻",text:"Core return received from <b>Alpha Garage</b> — 2 brake discs",status:"delivered",time:"6h ago"},
    {icon:"✅",text:"Escrow released for <b>PS-240571</b> — ${money(200)}",status:"accepted",time:"8h ago"},
  ];
  document.getElementById("dashActivity").innerHTML = activities.map(a=>`
    <div style="display:flex;align-items:flex-start;gap:12px;padding:10px 0;border-bottom:1px solid var(--border-soft);">
      <div style="font-size:16px;flex-shrink:0;margin-top:1px;">${a.icon}</div>
      <div style="flex:1;font-size:13.5px;">${a.text}</div>
      <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">
        <span class="status-pill ${a.status}" style="font-size:10.5px;">${a.status}</span>
        <span style="font-size:11px;color:var(--text-faint);">${a.time}</span>
      </div>
    </div>`).join("");

  renderRfq(); renderOrders(); renderCatalogTable();
}
function renderRfq(){
  document.getElementById("rfqTbody").innerHTML = supplierRfqs.map(r=>`<tr>
    <td><b class="mono">${r.id}</b></td>
    <td>${r.items.map(i=>i.name+"×"+i.qty).join(", ")}</td>
    <td>${r.workshop}</td>
    <td>${money(r.value)}</td>
    <td><span class="status-pill ${r.status}">${r.status}</span></td>
    <td>${r.status==="new"?`<button class="btn btn-amber btn-sm" onclick="acceptRfq('${r.id}')">Quote</button>`:`<button class="btn btn-ghost btn-sm">View</button>`}</td>
  </tr>`).join("");
}
function acceptRfq(id){ const r=supplierRfqs.find(x=>x.id===id); if(r){ r.status="quoted"; renderRfq(); renderSupplierDash(); showToast("Quote sent for "+id); } }
function renderOrders(){
  document.getElementById("orderTbody").innerHTML = supplierOrders.map(o=>`<tr>
    <td><b class="mono">${o.id}</b></td>
    <td>${o.items.map(i=>i.name+"×"+i.qty).join(", ")}</td>
    <td>${o.workshop}</td>
    <td>${money(o.value)}</td>
    <td><span class="status-pill ${o.status}">${o.status}</span></td>
    <td>${o.status==="fulfilling"?`<button class="btn btn-amber btn-sm" onclick="shipOrder('${o.id}')">Mark shipped</button>`:o.status==="shipped"?`<button class="btn btn-ghost btn-sm" onclick="deliverOrder('${o.id}')">Delivered</button>`:`<span style="color:var(--text-faint);font-size:12px;">—</span>`}</td>
  </tr>`).join("");
}
function shipOrder(id){ const o=supplierOrders.find(x=>x.id===id); if(o){ o.status="shipped"; renderOrders(); renderSupplierDash(); showToast("Order "+id+" marked as shipped"); } }
function deliverOrder(id){ const o=supplierOrders.find(x=>x.id===id); if(o){ o.status="delivered"; renderOrders(); renderSupplierDash(); showToast("Order "+id+" delivered ✓"); } }
function renderCatalogTable(){
  document.getElementById("catalogTbody").innerHTML = supplierCatalog.map((p,i)=>`<tr>
    <td><b>${p.name}</b></td>
    <td class="mono" style="font-size:12px;">${p.sku}</td>
    <td>${p.category}</td>
    <td>${money(p.price)}</td>
    <td>
      <div class="stock-bar-wrap">
        <div class="stock-bar"><div class="stock-bar-fill ${p.stock<5?"low":""}" style="width:${Math.min(100,p.stock/120*100)}%"></div></div>
        <span style="font-size:12px;">${p.stock}</span>
      </div>
    </td>
    <td><span class="status-pill ${p.active?"active":"inactive"}">${p.active?"Active":"Inactive"}</span></td>
    <td><button class="btn btn-ghost btn-sm" onclick="togglePart(${i})">${p.active?"Deactivate":"Activate"}</button></td>
  </tr>`).join("");
}
function togglePart(i){ supplierCatalog[i].active=!supplierCatalog[i].active; renderCatalogTable(); renderSupplierDash(); showToast((supplierCatalog[i].active?"Activated":"Deactivated")+": "+supplierCatalog[i].name); }
function openAddPart(){ showModal("addPartModal"); }
function closeAddPart(){ closeModal("addPartModal"); }
function saveNewPart(){
  const name = document.getElementById("apName").value.trim();
  const sku = document.getElementById("apSku").value.trim();
  if(!name||!sku){ showToast("Name and SKU are required"); return; }
  supplierCatalog.push({ name, sku, category:document.getElementById("apCat").value, price:+document.getElementById("apPrice").value||0, stock:+document.getElementById("apStock").value||0, active:document.getElementById("apStatus").value==="Active" });
  renderCatalogTable(); renderSupplierDash(); closeAddPart();
  ["apName","apSku","apPrice","apStock"].forEach(id=>document.getElementById(id).value="");
  showToast("Part added to catalog ✓");
}

/* ══ STATS ══ */
document.getElementById("statParts").textContent = PARTS.length;
document.getElementById("statSuppliers").textContent = new Set(PARTS.map(p=>p.brand)).size;

/* ══ INIT ══ */
buildCategoryPills();
buildSupplierStrip();
renderParts();
</script>
